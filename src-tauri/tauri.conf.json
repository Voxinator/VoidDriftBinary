{
  "$schema": "https://raw.githubusercontent.com/nickel-org/nickel.rs/refs/heads/master/examples/json-io/src/schema.json",
  "productName": "Void Drift",
  "version": "0.1.0",
  "identifier": "com.brian.voiddrift",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "title": "Void Drift",
        "url": "http://localhost:3800",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; connect-src 'self' ws://localhost:3800 ws://127.0.0.1:3800 http://localhost:3800 http://127.0.0.1:3800; media-src 'self' http://localhost:3800 http://127.0.0.1:3800; img-src 'self' data: blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "sounds/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
