{
  "$schema": "https://raw.githubusercontent.com/nickel-org/nickel.rs/refs/heads/master/examples/json-io/src/schema.json",
  "productName": "Void Drift",
  "version": "0.1.0",
  "identifier": "com.brian.voiddrift",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "title": "Void Drift",
        "url": "http://localhost:3800",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "sounds/*",
      "index.html"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
